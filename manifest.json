{
    "manifest_version": 3,
    "name": "Chrome Extension Starter MV3",
    "version": "1.0.0",
    "description": "Production-ready Chrome Extension Starter Template with TypeScript, React, Tailwind CSS, and Manifest V3.",
    "permissions": [
        "storage",
        "tabs"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
