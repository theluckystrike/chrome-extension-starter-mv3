{
    "name": "chrome-extension-starter-mv3",
    "version": "1.0.0",
    "description": "Production-ready Chrome Extension Starter Template with TypeScript, React, Tailwind CSS, and Manifest V3. The fastest way to build modern Chrome extensions.",
    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "private": true,
    "keywords": [
        "chrome-extension",
        "manifest-v3",
        "mv3",
        "boilerplate",
        "starter-template",
        "typescript",
        "react",
        "tailwindcss",
        "chrome",
        "browser-extension",
        "web-extension",
        "extension-template"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/chrome-extension-starter-mv3.git"
    },
    "homepage": "https://github.com/theluckystrike/chrome-extension-starter-mv3",
    "bugs": {
        "url": "https://github.com/theluckystrike/chrome-extension-starter-mv3/issues"
    },
    "scripts": {
        "dev": "webpack --mode development --watch",
        "build": "webpack --mode production",
        "package": "npm run build && cd dist && zip -r ../extension.zip .",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
        "type-check": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "icons": "node scripts/generate-icons.js",
        "setup": "node scripts/setup.js"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/chrome": "^0.0.260",
        "@types/jest": "^29.5.12",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@typescript-eslint/eslint-plugin": "^6.19.1",
        "@typescript-eslint/parser": "^6.19.1",
        "autoprefixer": "^10.4.17",
        "copy-webpack-plugin": "^12.0.2",
        "css-loader": "^6.10.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "html-webpack-plugin": "^5.6.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "mini-css-extract-plugin": "^2.8.0",
        "postcss": "^8.4.35",
        "postcss-loader": "^8.1.0",
        "prettier": "^3.2.4",
        "sharp": "^0.34.5",
        "tailwindcss": "^3.4.1",
        "ts-jest": "^29.1.2",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.4"
    }
}